
# --- LLM agents (optional — without a key, agents use deterministic heuristics)
ANTHROPIC_API_KEY=
ORACLE_MODEL=claude-haiku-4-5

# --- chain mode: "memory" (default, runs instantly) or "devnet"
CHAIN=memory

# --- feed: "sim" (default, fast demo rounds) or "txline" (real World Cup data)
FEED=sim
# TxLINE devnet settings (used when FEED=txline; free World Cup tier)
TXLINE_HOST=https://txline-dev.txodds.com
TXLINE_COMPETITION_ID=72
# TXLINE_WALLET=./.txline/wallet.json   # devnet wallet that pays the subscribe tx
TXLINE_MAX_FIXTURES=4
TXLINE_POLL_S=60

# devnet-only settings (used when CHAIN=devnet)
RPC_URL=https://api.devnet.solana.com
# KEYPAIR=/home/you/.config/solana/id.json
# IDL_PATH=../target/idl/oracle_league.json

# --- demo pacing (seconds)
COMMIT_WINDOW_S=20
PLAY_S=12
PAUSE_S=8
MATCHES_PER_ROUND=3
PORT=3000        # API process
WEB_PORT=8080    # frontend process (separate from the API)
# WEB_ORIGIN=http://localhost:8080   # lock API CORS to the frontend origin
